# ---------------------------------------------------------------------------
# ONDEWO VTSI nodejs client SDK - examples configuration template
#
# Copy/adjust these values for your environment. This file contains NO real
# secrets (placeholders only) and is committed as a template. Each example
# loads this file via dotenv (path is resolved relative to the script), then
# reads the variables below through process.env.
# ---------------------------------------------------------------------------

# --- Connection ------------------------------------------------------------
# Host and port of the VTSI gRPC server. Combined into "<host>:<port>".
ONDEWO_HOST=localhost
ONDEWO_PORT=40051

# --- Secure channel --------------------------------------------------------
# Use a TLS (SSL) gRPC channel instead of plaintext (true/false).
ONDEWO_USE_SECURE_CHANNEL=false
# Optional path to a PEM root-certificate file for the secure channel.
# Leave blank to use the system trust store when ONDEWO_USE_SECURE_CHANNEL=true.
ONDEWO_GRPC_CERT=

# --- Keycloak (bearer-token auth) ------------------------------------------
# Keycloak base URL, e.g. https://my-host/auth
KEYCLOAK_URL=
# Realm name, e.g. ondewo-ccai-platform
KEYCLOAK_REALM=
# PUBLIC Keycloak client id (no secret), e.g. ondewo-nlu-cai-sdk-public
KEYCLOAK_CLIENT_ID=
# Technical-user credentials used for the ROPC + offline_access login.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server's TLS certificate (true/false). Keep true in prod.
KEYCLOAK_VERIFY_SSL=true

# --- VTSI service-specific --------------------------------------------------
# Resource name of the VTSI project whose callers to list, e.g. projects/my-vtsi.
ONDEWO_VTSI_PROJECT_NAME=
